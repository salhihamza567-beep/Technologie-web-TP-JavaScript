<body>

<script>
let nombre = Math.floor(Math.random() * 10) + 1;
let tentative = 0;
let guess;

do {
    guess = parseInt(prompt("deviner un nombre entre 1 et 10"));
    tentative++;

    if (guess > nombre) {
        alert("le nombre et plus petit:");
    } else if (guess < nombre) {
        alert("le nombre et plus grand: ");
    } else {
        alert("braveau");
    }

} while (guess !== nombre);

console.log("le nombre de repitition :" + tentative);
</script>

</body>
</html>
